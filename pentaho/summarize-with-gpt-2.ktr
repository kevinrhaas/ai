      <to>Select values</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Select values</from>
      <to>JSON: Modify values from a single row</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>JSON: Extract to rows</from>
      <to>Text file output</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <step>
    <name>Filter rows</name>
    <type>FilterRows</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <send_true_to>Modified JavaScript value</send_true_to>
    <send_false_to>Add constants</send_false_to>
    <compare>
      <condition>
        <negated>N</negated>
        <leftvalue>content_bytes</leftvalue>
        <function>&gt;</function>
        <rightvalue>maxchars</rightvalue>
      </condition>
    </compare>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
      <input>
      </input>
      <output>
      </output>
