      <parameter>
        <name>MODEL</name>
        <default_value>gpt-3.5-turbo</default_value>
        <description/>
      </parameter>
      <parameter>
        <name>SYSTEM</name>
        <default_value>You are meeting transcript summarizer. You will take in the text of a section of a meeting and provide 5 bulleted items of the key events, opinions, activities and decisions. Just include the bullets in the response, no headers. Include people's names who spoke or were involved for each of the item produce the result using the following template items: - Asif has put together a deck with answers to some questions
- Eric and his team will address the majority of the questions
- Asif asks Eric to keep in mind the angle of what is currently possible when giving guidance and thoughts.</default_value>
        <description/>
      </parameter>
      <parameter>
        <name>TOKEN</name>
        <default_value>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</default_value>
        <description/>
      </parameter>
      <parameter>
        <name>TRIM</name>
        <default_value>Y</default_value>
        <description/>
      </parameter>
