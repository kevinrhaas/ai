        <default_value>16000</default_value>
        <description/>
      </parameter>
      <parameter>
        <name>MODEL</name>
        <default_value>gpt-3.5-turbo-16k</default_value>
        <description/>
      </parameter>
      <parameter>
        <name>MODEL_ALT</name>
        <default_value>gpt-4-0613</default_value>
