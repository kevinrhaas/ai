  <step>
    <name>js: estimate token count for trimming</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
function countTokens(text) {
  regex = /[\w]+|[^\s\w]/g;
  matches = text.match(regex);
  return matches ? matches.length : 0;
}


if (countTokens(content_user) >= parseInt(getVariable('MAXTOKENS','3500')) &amp;&amp; getVariable('TRIM','Y') == 'Y') 
	{
	//var content_user = 'x';
  	regex = /[\w]+|[^\s\w]/g;
  	tokens = content_user.match(regex);
  	tokens = tokens.slice(0, 3500);
  	var content_user= tokens.join('');
	var trimmed = 'Y'
	}
else
	{
	var trimmed = 'N';
	}




var filename_out = outpath + '/' + filename</jsScript_script>
      </jsScript>
    </jsScripts>
