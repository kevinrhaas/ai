    <sql>CREATE TABLE TRIAL_BALANCE_EXTENDED
(
    "Type" char(1),
    "Account_Num" integer,
    "Category" varchar(255)  ,
    "Category2" varchar(255)  ,
    "Detail" varchar(255) ,
    "Amount" integer,
    "Region" varchar(255) 
);

INSERT INTO TRIAL_BALANCE_EXTENDED ("Type","Account_Num","Category","Category2","Detail","Amount","Region") VALUES
	 ('I',4100,'Revenue','Direct Sales','Direct Sales',200000,'EMEA'),
	 ('I',4200,'Revenue','Channel Sales','Channel Sales',250000,'EMEA'),
	 ('I',5010,'Cost of goods','Cost of goods available for sale','Beginning inventory',-20000,'EMEA'),
	 ('I',5020,'Cost of goods','Cost of goods available for sale','Net purchases',-300000,'EMEA'),
	 ('I',5040,'Cost of goods','Ending inventory','Ending inventory',155000,'EMEA'),
	 ('E',5110,'Expenses','Selling expenses','Sales salaries',-28000,'EMEA'),
	 ('E',5120,'Expenses','Selling expenses','Nonrecurring item',-22000,'EMEA'),
	 ('E',5130,'Expenses','Selling expenses','Other',-3000,'EMEA'),
	 ('E',5310,'Expenses','General and administrative expenses','Office salaries',-97100,'EMEA'),
	 ('E',5320,'Expenses','General and administrative expenses','Depreciation',-2500,'EMEA');
INSERT INTO TRIAL_BALANCE_EXTENDED ("Type","Account_Num","Category","Category2","Detail","Amount","Region") VALUES
	 ('E',5330,'Expenses','General and administrative expenses','Amortization',-1200,'EMEA'),
	 ('E',5340,'Expenses','General and administrative expenses','Bad debt',-10500,'EMEA'),
	 ('E',5350,'Expenses','General and administrative expenses','Other',-29200,'EMEA'),
	 ('I',6110,'Other revenues','Interest','Interest',1200,'EMEA'),
	 ('I',6120,'Other revenues','Dividends','Dividends',25200,'EMEA'),
	 ('I',6130,'Other revenues','Gain on sale of equipment','Gain on sale of equipment',1600,'EMEA'),
	 ('E',7110,'Other expenses','Interest','Interest',-2400,'EMEA'),
	 ('E',7120,'Other expenses','Writeoff - goodwill','Writeoff - goodwill',-2000,'EMEA'),
