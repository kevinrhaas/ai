  <step>
    <name>js: format request</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// format the request

var data_string = {
    "model": model,
    "messages": [
        {
            "role": "system",
            "content": content_system
        },
        {
            "role": "user",
            "content": content_user
        }
    ],
    "temperature": temperature
}

var data_string = JSON.stringify(data_string)


// also assign a run name if blank

if (trim(run_name) == '') {

    var run_name = "Run " + yearval + monthval + day + hour + minute + second;

}</jsScript_script>
      </jsScript>
      <jsScript>
        <jsScript_type>1</jsScript_type>
        <jsScript_name>Item_0</jsScript_name>
        <jsScript_script>//Script here

var run_datetime = new Date();

var dateval = new Date();
var yearval = dateval.getFullYear();
var monthval = padWithZeros(dateval.getMonth() + 1, 2);  // JS months start at 0
var day = padWithZeros(dateval.getDate(), 2);
var hour = padWithZeros(dateval.getHours(), 2);
var minute = padWithZeros(dateval.getMinutes(), 2);
var second = padWithZeros(dateval.getSeconds(), 2);


function padWithZeros(number, length) {
    str = "" + number;
    while (str.length &lt; length) {
        str = "0" + str;
    }
    return str;
}</jsScript_script>
      </jsScript>
    </jsScripts>
