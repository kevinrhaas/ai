    <entry>
      <name>cat header and detail</name>
      <description />
      <type>SHELL</type>
      <attributes />
      <filename />
      <work_directory />
      <arg_from_previous>N</arg_from_previous>
      <exec_per_row>N</exec_per_row>
      <set_logfile>N</set_logfile>
      <logfile />
      <set_append_logfile>N</set_append_logfile>
      <logext />
      <add_date>N</add_date>
      <add_time>N</add_time>
      <insertScript>Y</insertScript>
      <script>#!/usr/bin/env bash
set -eo pipefail

# Bring in external vars
L_TMP_FOLDER_PATH="${V_TMP_FOLDER_PATH}"
L_SHORT_FILENAME="${short_filename}"

# Local vars only below this point
set -u
echo "L_TMP_FOLDER_PATH is (${L_TMP_FOLDER_PATH})"
echo "L_SHORT_FILENAME is (${L_SHORT_FILENAME})"

# check vars
if [[ -z "${L_TMP_FOLDER_PATH}" ]]; then
    echo "ERROR: The mandatory external variable (TMP_FOLDER_PATH) is empty."
    exit 1
fi
if [[ -z "${L_SHORT_FILENAME}" ]]; then
    echo "ERROR: The mandatory external variable (L_SHORT_FILENAME) is empty."
    exit 1
fi


# generate var values
L_ORIGINAL_INPUT_FILE="${L_TMP_FOLDER_PATH}/${L_SHORT_FILENAME}"
L_HDR_FILE_PATH="${L_TMP_FOLDER_PATH}/hdr_${L_SHORT_FILENAME}"
L_DETAIL_FILE_PATH="${L_TMP_FOLDER_PATH}/detail_${L_SHORT_FILENAME}"
L_FINAL_COMBINED_FILE_PATH="${L_TMP_FOLDER_PATH}/concat_${L_SHORT_FILENAME}"

# preflight
if [[ ! -d "${L_TMP_FOLDER_PATH}" ]]; then
    echo "ERROR: The temp folder path (${L_TMP_FOLDER_PATH}) DNE."
    exit 1
fi
if [[ ! -f "${L_HDR_FILE_PATH}" ]]; then
    echo "ERROR: The header file (${L_HDR_FILE_PATH}) DNE. Something went wrong before this step."
    exit 1
fi
if [[ ! -f "${L_DETAIL_FILE_PATH}" ]]; then
    echo "ERROR: The detail file (${L_DETAIL_FILE_PATH}) DNE. Something went wrong before this step."
    exit 1
fi
if [[ ! -f "${L_ORIGINAL_INPUT_FILE}" ]]; then
    echo "ERROR: The original input file (${L_ORIGINAL_INPUT_FILE}) DNE. Something went wrong before this step."
    exit 1
fi


# Write combined file
cat "${L_HDR_FILE_PATH}" "${L_DETAIL_FILE_PATH}" > "${L_FINAL_COMBINED_FILE_PATH}"


# Verify
if [[ ! -f "${L_FINAL_COMBINED_FILE_PATH}" ]]; then
    echo "ERROR: The final concat file (${L_FINAL_COMBINED_FILE_PATH}) DNE. Something went wrong."
    exit 1
fi

# remove original file
rm "${L_ORIGINAL_INPUT_FILE}"

# replace with. new concat file
mv "${L_FINAL_COMBINED_FILE_PATH}" "${L_ORIGINAL_INPUT_FILE}"

# remove temp files
rm "${L_HDR_FILE_PATH}"
rm "${L_DETAIL_FILE_PATH}"
</script>
