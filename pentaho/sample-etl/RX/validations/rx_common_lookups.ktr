    <formula>
      <field_name>enrollment_id</field_name>
      <formula_string>enrollment_id != null ? ((enrollment_id.endsWith("RX") || enrollment_id.endsWith("|")) ? enrollment_id : null) : null</formula_string>
      <value_type>String</value_type>
      <value_length>-1</value_length>
