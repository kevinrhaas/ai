    </entry>
    <entry>
      <name>Move Files to S3</name>
      <description />
      <type>SHELL</type>
      <attributes />
      <filename />
      <work_directory>/pentaho-workspace/data/${V_pentaho_folder_name}/staging/</work_directory>
      <arg_from_previous>N</arg_from_previous>
      <exec_per_row>N</exec_per_row>
      <set_logfile>N</set_logfile>
      <logfile />
      <set_append_logfile>N</set_append_logfile>
      <logext />
      <add_date>N</add_date>
      <add_time>N</add_time>
      <insertScript>Y</insertScript>
      <script>#!/bin/bash

aws s3 cp ${V_data_key}_pharmacy_claim_staging_${V_icn}.csv s3://aver-client-${V_data_key}/integration/etl/staging/${V_data_key}_pharmacy_claim_staging_${V_icn}.csv
</script>
      <loglevel>Basic</loglevel>
      <parallel>N</parallel>
      <draw>Y</draw>
      <nr>0</nr>
      <xloc>720</xloc>
      <yloc>96</yloc>
      <attributes_kjc />
    </entry>
    <entry>
      <name>Update Redshift</name>
      <description />
      <type>SQL</type>
      <attributes />
      <sql>COPY ${V_schema_name}.pharmacy_claim
(id,member_id,enrollment_id,dispensing_facility_id,prescribing_provider_id,adjustment_code,average_wholesale_price,billed_amount,brand_generic_indicator_code,claim_id,cob_amount,coinsurance_amount,copay_amount,days_supply,deductible_amount,dispense_as_written_code,dispensing_fee_amount,fill_date,ingredient_cost,liability_amount,line_number,load_date,maintenance_drug_indicator,national_drug_code,net_allowed_amount,paid_amount,paid_date,paid_in_network_indicator,prescription_date,prescription_number,quantity,refill_number,source_document_control_number,therapeutic_class_code,therapeutic_group_code)
FROM 's3://aver-client-${V_data_key}/integration/etl/staging/${V_data_key}_pharmacy_claim_staging_${V_icn}.csv' 
iam_role 'arn:aws:iam::781803879514:role/redshift-pentaho-role'
CSV;

update ${V_schema_name}.pharmacy_claim
set enrollment_id = e.id
from ${V_schema_name}.enrollment e
where pharmacy_claim.member_id = e.member_id
and (pharmacy_claim.fill_date >= e.effective_date
and pharmacy_claim.fill_date &lt;= e.termination_date)
and pharmacy_claim.source_document_control_number = '${V_icn}'
and e.benefit_type_code = 'RX'
;

--PRESCRIBING_PROVIDER_BY_MEMBER------------------------------------------------------------------
BEGIN; truncate table ${V_schema_name}.prescribing_provider_by_member;
insert into ${V_schema_name}.prescribing_provider_by_member (
select 
distinct pc.member_id,
pc.prescribing_provider_id as id,
pc.prescribing_provider_id as provider_id,
p.npi as npi,
p.client_defined_field_value_3 as provider_type,
p.first_name,
p.last_name_or_organization_name as last_name,
case 
	when p.first_name is not NULL and p.last_name_or_organization_name is not NULL then p.last_name_or_organization_name ||', '||p.first_name else NULL end as full_name,
NULL as address_line_1,
NULL as address_line_2,
NULL as city,
p.practice_state as state,
p.practice_zip_code as zip_code,
p.taxonomy_code,
p.organization_id,
p.organization_name,
p.specialty_type_code,
NULL as client_specialty_type,
NULL as dea_number,
p.affiliation_id as affiliation,
NULL::boolean as preferred_network_indicator,
p.tax_id,
NULL::timestamp as load_timestamp,
pc.source_document_control_number,
pc.load_date 
from ${V_schema_name}.pharmacy_claim pc
join ${V_schema_name}.providers p on p.payer_provider_id = pc.prescribing_provider_id
);

--DISPENSING_FACILITY_BY_MEMBER------------------------------------------------------------------
BEGIN; truncate table ${V_schema_name}.dispensing_facility_by_member;
insert into ${V_schema_name}.dispensing_facility_by_member (
select 
distinct pc.member_id,
pc.dispensing_facility_id as id,
pc.dispensing_facility_id as facility_id,
p.npi as npi,
case
	when p.first_name is not NULL and p.last_name_or_organization_name is not NULL then p.last_name_or_organization_name||', '||p.first_name else NULL end as full_name,
NULL as address_line_1,
NULL as address_line_2,
NULL as city,
p.practice_state as state,
p.practice_zip_code as zip_code,
p.taxonomy_code,
NULL as pharmacy_type_code,
p.client_defined_field_value_3 as provider_type,
p.specialty_type_code,
NULL as client_specialty_type,
NULL::timestamp as load_timestamp,
pc.source_document_control_number,
pc.load_date 
from ${V_schema_name}.pharmacy_claim pc
left join ${V_schema_name}.providers p on p.payer_provider_id = pc.dispensing_facility_id
);


--UPDATE_ENROLLMENT_FROM_RX-------------------------------------------------------

INSERT INTO ${V_schema_name}.enrollment (
id,
member_id,
relationship,
account_id,
corporate_entity_code,
benefit_type_code,
effective_date,
employer_id,
employer_name,
enrollment_member_id,
group_id,
line_of_business,
major_customer_segment,
multi_coverage_indicator,
pcp_indicator,
plan_code,
plan_funding_type,
product_category,
product_code,
termination_date,
dual_status_code,
family_id,
medicare_entitlement_code,
medicare_orec_code,
medicare_status_code,
mhsa_coverage_indicator,
coverage_type,
division,
group_name,
health_plan_member_id,
health_plan_state,
internal_member_id,
last_change_date,
load_timestamp,
medicaid_id,
medicare_id,
product,
program,
source_document_control_number,
subscriber_id,
policy_number,
coverage_type_code,
health_plan_product_name,
load_date
)
select
distinct p.enrollment_id as id,
p.member_id as member_id,
'18' as relationship,
NULL as account_id,
NULL as corporate_entity_code,
'RX' as benefit_type_code,
NULL::date as effective_date,
NULL as employer_id,
NULL as employer_name,
NULL as enrollment_member_id,
NULL as group_id,
NULL as line_of_business,
NULL as major_customer_segment,
NULL::boolean as multi_coverage_indicator,
'f'::boolean as pcp_indicator,
NULL as plan_code,
NULL as plan_funding_type,
NULL as product_category,
NULL as product_code,
NULL::date as termination_date,
NULL as dual_status_code,
NULL as family_id,
NULL as medicare_entitlement_code,
NULL as medicare_orec_code,
NULL as medicare_status_code,
NULL::boolean as mhsa_coverage_indicator,
NULL as coverage_type,
NULL as division,
NULL as group_name,
p.member_id as health_plan_member_id,
NULL as health_plan_state,
NULL as internal_member_id,
p.load_date as last_change_date,
p.load_timestamp,
NULL as medicaid_id,
NULL as medicare_id,
NULL as product,
NULL as program,
p.source_document_control_number,
NULL as subscriber_id,
NULL as policy_number,
NULL as coverage_type_code,
NULL as health_plan_product_name,
p.load_date
from ${V_schema_name}.pharmacy_claim p
where enrollment_id NOT IN (
		select id from ${V_schema_name}.enrollment
);

</sql>
