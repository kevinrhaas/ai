    <sql>--ATTENDING_PROVIDER--
drop table if exists "${V_schema_name}".attending_provider cascade;

create table "${V_schema_name}".attending_provider (
id varchar(256) NOT NULL  ENCODE lzo,
address_line_1 varchar(256) ENCODE lzo,
address_line_2 varchar(256) ENCODE lzo,
city varchar(256) ENCODE lzo,
first_name varchar(256) ENCODE lzo,
full_name varchar(256) ENCODE lzo,
last_name varchar(256) ENCODE lzo,
load_timestamp timestamp  NOT NULL  ENCODE lzo,
npi varchar(256) NOT NULL  ENCODE lzo,
provider_id varchar(256) NOT NULL  ENCODE lzo,
provider_type varchar(256) ENCODE lzo,
source_document_control_number varchar(256) NOT NULL  ENCODE lzo,
specialty_type_code varchar(256) ENCODE lzo,
state varchar(2) ENCODE lzo,
tax_id varchar(256) NOT NULL  ENCODE lzo,
taxonomy_code varchar(256) ENCODE lzo,
zip_code varchar(5) ENCODE lzo,
primary key(id)
);

drop table if exists "${V_schema_name}".attending_provider_by_member cascade;

create table "${V_schema_name}".attending_provider_by_member (
member_id  varchar(256) NOT NULL  ENCODE lzo,
id varchar(256) NOT NULL  ENCODE lzo,
address_line_1 varchar(256) ENCODE lzo,
address_line_2 varchar(256) ENCODE lzo,
city varchar(256) ENCODE lzo,
first_name varchar(256) ENCODE lzo,
full_name varchar(256) ENCODE lzo,
last_name varchar(256) ENCODE lzo,
load_timestamp timestamp  NOT NULL  ENCODE lzo,
npi varchar(256) NOT NULL  ENCODE lzo,
provider_id varchar(256) NOT NULL  ENCODE lzo,
provider_type varchar(256) ENCODE lzo,
source_document_control_number varchar(256) NOT NULL  ENCODE lzo,
specialty_type_code varchar(256) ENCODE lzo,
state varchar(2) ENCODE lzo,
tax_id varchar(256) NOT NULL  ENCODE lzo,
taxonomy_code varchar(256) ENCODE lzo,
zip_code varchar(5) ENCODE lzo
);</sql>
