  <entries>
    <entry>
      <name>Start</name>
      <description />
      <type>SPECIAL</type>
      <attributes />
      <start>Y</start>
      <dummy>N</dummy>
      <repeat>N</repeat>
      <schedulerType>0</schedulerType>
      <intervalSeconds>0</intervalSeconds>
      <intervalMinutes>60</intervalMinutes>
      <hour>12</hour>
      <minutes>0</minutes>
      <weekDay>1</weekDay>
      <DayOfMonth>1</DayOfMonth>
      <parallel>N</parallel>
      <draw>Y</draw>
      <nr>0</nr>
      <xloc>192</xloc>
      <yloc>256</yloc>
      <attributes_kjc />
    </entry>
    <entry>
      <name>Check Vars and Move Data to Staging</name>
      <description />
      <type>SHELL</type>
      <attributes />
      <filename />
      <work_directory>/pentaho-workspace/data/${V_pentaho_folder_name}/staging_output/${V_icn}/</work_directory>
      <arg_from_previous>N</arg_from_previous>
      <exec_per_row>N</exec_per_row>
      <set_logfile>N</set_logfile>
      <logfile />
      <set_append_logfile>N</set_append_logfile>
      <logext />
      <add_date>N</add_date>
      <add_time>N</add_time>
      <insertScript>Y</insertScript>
      <script>#!/bin/bash

set -eo pipefail

if [ -z "${V_filetype}" ]
then
    exit "File type [V_filetype] was not set - job could not continue"
fi

if [ -z "${V_icn}" ]
then
    exit "ICN [V_icn] was not set - job could not continue"
fi

eligibility_filetypes="ELIGCHG ELIGFULL"
pre_authorization_filetypes="AUTH NOTIF ROSTER"
bbm_file_type=

for i in $eligibility_filetypes; do
    if [ "$i" = "${V_filetype}" ]
    then
        bbm_file_type="member_eligibility"
    fi  
done

for i in $pre_authorization_filetypes; do
    if [ "$i" = "${V_filetype}" ]
    then
        bbm_file_type="pre_authorization"
    fi  
done

if [ "CLMPP" = "${V_filetype}" ]
then
    bbm_file_type="unpaid_medical_claims"
fi

if [ "CLMP" = "${V_filetype}" ]
then
    bbm_file_type="paid_medical_claims"
fi

if [ "CLMB" = "${V_filetype}" ]
then
    bbm_file_type="batch_claims"
fi

if [ -n "$bbm_file_type" ]
then
    if [ -z "${V_member_count}" ]
    then
        exit "Member count [V_member_count] was not set, job could not continue"
    fi  
    echo "{\"source_document_control_number\":\"${V_icn}\",\"file_type\":\"${bbm_file_type}\",\"total_member_count\":${V_member_count}}" > ./${V_icn}_file_tracking_message
    cat ./${V_icn}_file_tracking_message
    aws s3 mv ./${V_icn}_file_tracking_message s3://${V_staging_bucket}/

    aws s3 mv --recursive ./ s3://${V_staging_bucket}/${V_icn}/
fi
    </script>
      <loglevel>Basic</loglevel>
      <parallel>N</parallel>
      <draw>Y</draw>
      <nr>0</nr>
      <xloc>720</xloc>
      <yloc>336</yloc>
      <attributes_kjc />
    </entry>
    <entry>
      <name>Delete folders</name>
      <description />
      <type>DELETE_FOLDERS</type>
      <attributes />
      <arg_from_previous>N</arg_from_previous>
