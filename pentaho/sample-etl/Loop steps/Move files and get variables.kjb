    <entry>
      <name>Check download folder for files</name>
      <description />
      <type>FOLDER_IS_EMPTY</type>
      <attributes />
      <foldername>/pentaho-workspace/data/${V_pentaho_folder_name}/download/</foldername>
      <include_subfolders>N</include_subfolders>
      <specify_wildcard>Y</specify_wildcard>
      <wildcard>.*\.csv</wildcard>
