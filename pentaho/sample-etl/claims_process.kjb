      <draw>Y</draw>
      <nr>0</nr>
      <xloc>1408</xloc>
      <yloc>448</yloc>
      <attributes_kjc />
    </entry>
    <entry>
      <name>Update Redshift</name>
      <description />
      <type>SQL</type>
      <attributes />
      <sql>COPY ${V_schema_name}.medical_claim_header
(attending_provider_id,referring_provider_id,claim_type,id,member_id,enrollment_id,admit_date,allowed_amount,authorization_number,claim_status_code,billed_amount,claim_adjustment_indicator,claim_id,claim_member_id,cob_amount,coinsurance_amount,copay_amount,deductible_amount,discharge_date,first_date_of_service,last_date_of_service,load_timestamp,noncovered_amount,other_insurance_indicator,paid_amount,paid_date,previous_claim_id,source_document_control_number,source_file_type,load_date,billing_provider_id,type_of_bill_code,admit_source_code,admit_type_code,discharge_status_code,admit_diagnosis_code,icd_version,principal_procedure_date,received_date,principal_procedure_code,operating_provider_id,servicing_location_id,ms_drg_code,apr_drg_code,ap_drg_code,claim_type_code,internal_claim_id,home_host_indicator,paid_in_network_indicator,primary_paid_amount,severity_of_illness_code,cms_certification_number,admit_region_code,outpatient_priority_code,claim_service_type_code,day_utilization_type_code,medicare_nonpayment_reason_code)
FROM 's3://aver-client-${V_data_key}/integration/etl/staging/${V_data_key}_medical_claim_header_staging_${V_icn}.csv' 
iam_role 'arn:aws:iam::781803879514:role/redshift-pentaho-role'
EMPTYASNULL
CSV;

COPY ${V_schema_name}.medical_claim_line
(adjustment_code,adjustment_indicator,adjustment_number,allowed_amount,billed_amount,cob_amount,coinsurance_amount,copay_amount,cpt_hcpcs_code,cpt_hcpcs_modifier1,cpt_hcpcs_modifier2,cpt_hcpcs_modifier3,cpt_hcpcs_modifier4,cpt_hcpcs_modifier5,cpt_hcpcs_modifier6,deductible_amount,denial_code,id,line_number,load_date,load_timestamp,medical_claim_header_id,member_id,noncovered_amount,paid_amount,paid_date,payment_status,place_of_service_code,principal_diagnosis_code,principal_diagnosis_icd_version,principal_diagnosis_poa_code,procedure_code_type,rendering_provider_id,revenue_code,service_end_date,service_start_date,service_units,source_document_control_number,source_file_type,ordering_provider_id,last_adjusted_indicator,catastrophic_amount,internal_line_number,financial_group_code,financial_subgroup_code,other_insurance_allowed_amount,primary_paid_amount,primary_payer_code,type_of_service_code,processing_indicator_code)
FROM 's3://aver-client-${V_data_key}/integration/etl/staging/${V_data_key}_medical_claim_line_staging_${V_icn}.csv' 
iam_role 'arn:aws:iam::781803879514:role/redshift-pentaho-role'
EMPTYASNULL
CSV;

COPY ${V_schema_name}.procedure
(id,load_timestamp,source_document_control_number,member_id,medical_claim_header_id,icd_version,source_file_type,sequence,load_date,code,service_date)
FROM 's3://aver-client-${V_data_key}/integration/etl/staging/${V_data_key}_procedure_staging_${V_icn}.csv' 
iam_role 'arn:aws:iam::781803879514:role/redshift-pentaho-role'
EMPTYASNULL
CSV;

COPY ${V_schema_name}.diagnosis
(id,load_timestamp,source_document_control_number,member_id,medical_claim_line_id,icd_version,sequence,source_file_type,load_date,code,present_on_admission_code)
FROM 's3://aver-client-${V_data_key}/integration/etl/staging/${V_data_key}_diagnosis_staging_${V_icn}.csv' 
iam_role 'arn:aws:iam::781803879514:role/redshift-pentaho-role'
EMPTYASNULL
CSV;


--UPDATE MAXIMUM_DATA_DATE IN MEMBER-----------------------------------------------
--update ${V_schema_name}.member
--set maximum_data_date = 

--UPDATE ENROLLMENT_ID IN MCH------------------------------------------------------
update ${V_schema_name}.medical_claim_header
set enrollment_id = e.id
from ${V_schema_name}.enrollment e
where medical_claim_header.member_id = e.member_id
and (medical_claim_header.first_date_of_service >= e.effective_date
and medical_claim_header.first_date_of_service &lt;= e.termination_date)
--and e.benefit_type_code = 'MED' 
and medical_claim_header.source_document_control_number = '${V_icn}'
;




--BILLING_PROVIDER_BY_MEMBER------------------------------------------------------------------
insert into ${V_schema_name}.billing_provider_by_member (member_id,id,address_line_1,address_line_2,affiliation,city,client_specialty_type,contract_effective_date,contract_expiration_date,first_name,full_name,last_name,load_timestamp,middle_name,npi,organization_id,organization_name,organization_npi,organization_state,organization_zip_code,preferred_network_indicator,provider_id,provider_type,source_document_control_number,specialty_type_code,state,tax_id,taxonomy_code,zip_code,load_date)
(
select 
distinct h.member_id,
h.billing_provider_id as id,
p.address_line_1,
p.address_line_2,
p.affiliation_id as affiliation,
p.city,
p.client_specialty_type,
p.effective_date as contract_effective_date,
p.termination_date as contract_expiration_date,
p.first_name,
p.full_name,
p.last_name_or_organization_name as last_name,
h.load_timestamp,
p.middle_name,
p.npi,
p.organization_id,
p.organization_name,
p.organization_npi,
p.organization_state,
p.organization_zip_code,
p.preferred_network_indicator,
h.billing_provider_id as provider_id,
p.provider_type,
h.source_document_control_number,
p.specialty_type_code,
p.state,
p.tax_id,
p.taxonomy_code,
p.zip_code,
h.load_date
from ${V_schema_name}.medical_claim_header h
left join ${V_schema_name}.provider_roster p on p.provider_id = h.billing_provider_id
where h.source_document_control_number = '${V_icn}'
);


