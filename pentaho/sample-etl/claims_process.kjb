      <insertScript>Y</insertScript>
      <script>#!/bin/bash

aws s3 cp ${V_data_key}_medical_claim_header_staging_${V_icn}.csv s3://aver-client-${V_data_key}/integration/etl/staging/${V_data_key}_medical_claim_header_staging_${V_icn}.csv
aws s3 cp ${V_data_key}_medical_claim_line_staging_${V_icn}.csv s3://aver-client-${V_data_key}/integration/etl/staging/${V_data_key}_medical_claim_line_staging_${V_icn}.csv
aws s3 cp ${V_data_key}_procedure_staging_${V_icn}.csv s3://aver-client-${V_data_key}/integration/etl/staging/${V_data_key}_procedure_staging_${V_icn}.csv
aws s3 cp ${V_data_key}_diagnosis_staging_${V_icn}.csv s3://aver-client-${V_data_key}/integration/etl/staging/${V_data_key}_diagnosis_staging_${V_icn}.csv</script>
      <loglevel>Basic</loglevel>
