    </partitioning>
    <send_true_to>DRG Type MS Checks</send_true_to>
    <send_false_to>admit date range check</send_false_to>
    <compare>
      <condition>
        <negated>N</negated>
        <leftvalue>DRG Type</leftvalue>
        <function>=</function>
        <rightvalue />
        <value>
          <name>constant</name>
          <type>String</type>
          <text>MS</text>
          <length>-1</length>
          <precision>-1</precision>
          <isnull>N</isnull>
          <mask />
        </value>
      </condition>
    </compare>
