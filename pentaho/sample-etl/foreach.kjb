    <entry>
      <name>Split Header from Detail</name>
      <description />
      <type>SHELL</type>
      <attributes />
      <filename />
      <work_directory />
      <arg_from_previous>N</arg_from_previous>
      <exec_per_row>N</exec_per_row>
      <set_logfile>N</set_logfile>
      <logfile />
      <set_append_logfile>N</set_append_logfile>
      <logext />
      <add_date>N</add_date>
      <add_time>N</add_time>
      <insertScript>Y</insertScript>
      <script>head -n 1 ${filename} > /pentaho-workspace/data/${V_pentaho_folder_name}/setl_staging/hdr_${short_filename}

