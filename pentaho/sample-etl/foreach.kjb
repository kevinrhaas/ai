      <add_date>N</add_date>
      <add_time>N</add_time>
      <insertScript>Y</insertScript>
      <script>#!/usr/bin/env bash
set -eo pipefail

# Bring in external vars
L_FILENAME="${filename}"

# Local vars only below this point
set -u
echo "L_FILENAME is (${L_FILENAME})"

# check vars
if [[ -z "${L_FILENAME}" ]]; then
    echo "ERROR: The mandatory external variable (L_FILENAME) is empty."
    exit 1
fi
if [[ ! -f "${L_FILENAME}" ]]; then
    echo "ERROR: The filename (L_FILENAME) already DNE. Something went wrong before this step."
    exit 1
fi

# Do the things
rm "${L_FILENAME}"
</script>
