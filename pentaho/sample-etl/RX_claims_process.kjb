      <insertScript>Y</insertScript>
      <script>#!/bin/bash

aws s3 cp ${V_data_key}_pharmacy_claim_staging_${V_icn}.csv s3://aver-client-${V_data_key}/integration/etl/staging/${V_data_key}_pharmacy_claim_staging_${V_icn}.csv
</script>
      <loglevel>Basic</loglevel>
      <parallel>N</parallel>
      <draw>Y</draw>
      <nr>0</nr>
      <xloc>1296</xloc>
      <yloc>544</yloc>
      <attributes_kjc />
    </entry>
    <entry>
      <name>Update Redshift</name>
      <description />
      <type>SQL</type>
      <attributes />
      <sql>COPY ${V_schema_name}.pharmacy_claim
(id,member_id,enrollment_id,dispensing_facility_id,prescribing_provider_id,adjustment_code,average_wholesale_price,billed_amount,brand_generic_indicator_code,claim_id,cob_amount,coinsurance_amount,copay_amount,days_supply,deductible_amount,dispense_as_written_code,dispensing_fee_amount,fill_date,ingredient_cost,liability_amount,line_number,load_date,maintenance_drug_indicator,national_drug_code,net_allowed_amount,paid_amount,paid_date,paid_in_network_indicator,prescription_date,prescription_number,quantity,refill_number,source_document_control_number,therapeutic_class_code,therapeutic_group_code)
FROM 's3://aver-client-${V_data_key}/integration/etl/staging/${V_data_key}_pharmacy_claim_staging_${V_icn}.csv' 
iam_role 'arn:aws:iam::781803879514:role/redshift-pentaho-role'
EMPTYASNULL
CSV;

--update ${V_schema_name}.pharmacy_claim
--set enrollment_id = e.id
--from ${V_schema_name}.enrollment e
--where pharmacy_claim.member_id = e.member_id
--and (pharmacy_claim.fill_date >= e.effective_date
--and pharmacy_claim.fill_date &lt;= e.termination_date)
--and pharmacy_claim.source_document_control_number = '${V_icn}'
--and e.benefit_type_code = 'RX'
--;

--PRESCRIBING_PROVIDER_BY_MEMBER------------------------------------------------------------------
insert into ${V_schema_name}.prescribing_provider_by_member (member_id,id,address_line_1,address_line_2,affiliation,city,client_specialty_type,dea_number,first_name,full_name,last_name,npi,organization_id,organization_name,preferred_network_indicator,provider_id,provider_type,specialty_type_code,state,tax_id,taxonomy_code,zip_code,source_document_control_number,load_date,load_timestamp)
(
select 
distinct pc.member_id,
pc.prescribing_provider_id,
p.address_line_1,
p.address_line_2,
p.affiliation_id,
p.city,
p.client_specialty_type,
p.dea_number,
p.first_name,
p.full_name,
p.last_name_or_organization_name,
p.npi,
p.organization_id,
p.organization_name,
p.preferred_network_indicator,
pc.prescribing_provider_id,
p.provider_type,
p.specialty_type_code,
p.state,
p.tax_id,
p.taxonomy_code,
p.zip_code,
pc.source_document_control_number,
pc.load_date,
GETDATE() as load_timestamp 
from ${V_schema_name}.pharmacy_claim pc
join ${V_schema_name}.provider_roster p on p.provider_id = pc.prescribing_provider_id
where pc.source_document_control_number = '${V_icn}'
);

--DISPENSING_FACILITY_BY_MEMBER------------------------------------------------------------------
insert into ${V_schema_name}.dispensing_facility_by_member (member_id,id,address_line_1,address_line_2,city,client_specialty_type,facility_id,full_name,npi,pharmacy_type_code,provider_type,specialty_type_code,state,taxonomy_code,zip_code,source_document_control_number,load_date,load_timestamp)
(
select 
distinct pc.member_id,
pc.dispensing_facility_id as id,
p.address_line_1,
p.address_line_2,
p.city,
p.client_specialty_type,
pc.dispensing_facility_id as facility_id,
p.full_name,
p.npi,
p.pharmacy_type_code,
p.provider_type,
p.specialty_type_code,
p.state,
p.taxonomy_code,
p.zip_code,
pc.source_document_control_number,
pc.load_date,
GETDATE() as load_timestamp 
from ${V_schema_name}.pharmacy_claim pc
left join ${V_schema_name}.provider_roster p on p.provider_id = pc.dispensing_facility_id
where pc.source_document_control_number = '${V_icn}'
);


--UPDATE_ENROLLMENT_FROM_RX-------------------------------------------------------
--RXCLMB hardcoded for enrollment source_file_type
INSERT INTO ${V_schema_name}.enrollment (id,member_id,effective_date,termination_date,account_id,corporate_entity_code,benefit_type_code,division,dual_status_code,employer_id,employer_name,enrollment_member_id,family_id,group_id,health_plan_member_id,health_plan_state,internal_member_id,last_change_date,line_of_business,load_timestamp,major_customer_segment,medicaid_id,medicare_entitlement_code,medicare_id,medicare_orec_code,medicare_status_code,mhsa_coverage_indicator,multi_coverage_indicator,pcp_indicator,plan_code,policy_number,relationship,source_document_control_number,subscriber_id,coverage_type,group_name,health_plan_product_name,load_date,product,program,source_file_type)
select
distinct p.enrollment_id as id,
p.member_id as member_id,
NULL::date as effective_date,
NULL::date as termination_date,
NULL as account_id,
NULL as corporate_entity_code,
'RX' as benefit_type_code,
NULL as division,
NULL as dual_status_code,
NULL as employer_id,
NULL as employer_name,
NULL as enrollment_member_id,
NULL as family_id,
NULL as group_id,
p.member_id as health_plan_member_id,
NULL as health_plan_state,
NULL as internal_member_id,
p.load_date as last_change_date,
NULL as line_of_business,
GETDATE() as load_timestamp,
NULL as major_customer_segment,
NULL as medicaid_id,
NULL as medicare_entitlement_code,
NULL as medicare_id,
NULL as medicare_orec_code,
NULL as medicare_status_code,
NULL::boolean as mhsa_coverage_indicator,
NULL::boolean as multi_coverage_indicator,
'f'::boolean as pcp_indicator,
NULL as plan_code,
NULL as policy_number,
'18' as relationship,
p.source_document_control_number,
NULL as subscriber_id,
NULL as coverage_type,
NULL as group_name,
NULL as health_plan_product_name,
p.load_date,
NULL as product,
NULL as program,
'RXCLMB' as source_file_type
from ${V_schema_name}.pharmacy_claim p
where enrollment_id NOT IN (
		select id from ${V_schema_name}.enrollment
)
and p.source_document_control_number = '${V_icn}';

</sql>
