      <name>Insert Errors and Rejects</name>
      <description />
      <type>SQL</type>
      <attributes />
      <sql>COPY ${V_schema_name}.errors_and_rejects_details
(payer_reference_id,file_type,interchange_control_number,interchange_date,interchange_time,sender_id,receiver_id,sequence,number_of_errors,error_field,error_code,error_description,etl_date,etl_time,payer_reference_qualifier,transaction_processing_status)
FROM 's3://aver-client-${V_data_key}/integration/etl/staging/${V_icn}_errors_and_rejects.csv' 
iam_role 'arn:aws:iam::781803879514:role/redshift-pentaho-role'
CSV;</sql>
