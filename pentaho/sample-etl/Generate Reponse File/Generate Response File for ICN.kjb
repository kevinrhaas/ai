      <insertScript>Y</insertScript>
      <script>#!/bin/bash

if ls *${V_icn}_errors_and_rejects.csv 1> /dev/null 2>&amp;1
then
    cat *${V_icn}_errors_and_rejects.csv >> ${V_icn}_errors_and_rejects.csv
fi</script>
