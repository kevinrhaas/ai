    </entry>
    <entry>
      <name>Move response files to from_aver</name>
      <description />
      <type>SHELL</type>
      <attributes />
      <filename />
      <work_directory>/pentaho-workspace/data/${V_pentaho_folder_name}/outbound/</work_directory>
      <arg_from_previous>N</arg_from_previous>
      <exec_per_row>N</exec_per_row>
      <set_logfile>N</set_logfile>
      <logfile />
      <set_append_logfile>N</set_append_logfile>
      <logext />
      <add_date>N</add_date>
      <add_time>N</add_time>
      <insertScript>Y</insertScript>
      <script>#!/bin/bash

set -eo pipefail

V_bucket_name="aver-client-${V_data_key}"

if [[ ${V_bucket_name} == *bbmdev* ]]
then
    ROLE_INFO=`aws sts assume-role --duration-seconds "3600" --role-arn "arn:aws:iam::708693331984:role/bbmdev-admin" --role-session-name "pentaho-$PENTAHO_ENV"`
    export AWS_ACCESS_KEY_ID=`echo $ROLE_INFO | jq -r '.Credentials.AccessKeyId'`
    export AWS_SECRET_ACCESS_KEY=`echo $ROLE_INFO | jq -r '.Credentials.SecretAccessKey'`
    export AWS_SESSION_TOKEN=`echo $ROLE_INFO | jq -r '.Credentials.SessionToken'`
    echo "assumed bbmdev-admin role"
fi

if [ -z "$AWS_DEFAULT_REGION" ]; then export AWS_DEFAULT_REGION='us-east-1'; fi

#aws s3 mv ${V_response_short_filename} s3://${V_bucket_name}/sftp/${V_environment}/from_aver/
#aws s3 mv ${V_response_short_filename} s3://${V_bucket_name}/integration/response_files/
#if [[ ${V_filetype} == *NOTIF* ]]
#then
#  aws s3 mv ${V_response_short_filename} s3://${V_int_from_aver}/etl_response/notification_response/

#file="${V_response_short_filename}"
#if [ ${V_filetype} == "NOTIF" ] &amp;&amp; 
#if [[ ${V_filetype} == *NOTIF* ]]
#then
#  aws s3 mv ${V_response_short_filename} s3://${V_int_from_aver}/etl_response/notification_response/

echo "filetype is ${V_filetype}"
echo "response file is ${V_response_short_filename}"
echo "file status is ${V_file_processing_status}"

if [ ${V_filetype} == "NOTIF" ] &amp;&amp;  [ ${V_response_short_filename: -5} == ".json" ]
then
    aws s3 mv ${V_response_short_filename} s3://${V_int_from_aver}/DEV/notification_response/
elif [ ${V_filetype} == "NOTIF" ] &amp;&amp; [ ${V_response_short_filename: -4} == ".csv" ]
then
    aws s3 mv ${V_response_short_filename} s3://${V_int_from_aver}/DEV/notification_response/
elif [[ ${V_filetype} == *ROSTER* ]]
then    
    aws s3 mv ${V_response_short_filename} s3://${V_int_from_aver}/DEV/episode_roster_response/
elif [[ ${V_filetype} == *ELIGCHG* ]]
then
    aws s3 mv ${V_response_short_filename} s3://${V_int_from_aver}/DEV/member_eligibility_change/
elif [[ ${V_filetype} == *ELIGAUDIT* ]]
then
    aws s3 mv ${V_response_short_filename} s3://${V_int_from_aver}/DEV/member_eligibility_replacement/
elif [[ ${V_filetype} == *ELIGREPLACE* ]]
then
    aws s3 mv ${V_response_short_filename} s3://${V_int_from_aver}/DEV/member_eligibility_audit_response/
elif [[ ${V_filetype} == *ELIGFULL* ]]
then
    aws s3 mv ${V_response_short_filename} s3://${V_int_from_aver}/DEV/member_eligibility_audit_response/
elif [[ ${V_filetype} == *CLMP* ]]
then
    aws s3 mv ${V_response_short_filename} s3://${V_int_from_aver}/DEV/paid_medical_claims_response/
elif [[ ${V_filetype} == *CLMPP* ]]
then
    aws s3 mv ${V_response_short_filename} s3://${V_int_from_aver}/DEV/prepaid_medical_claim_response/
elif [[ ${V_filetype} == *CLMB* ]]
then
    aws s3 mv ${V_response_short_filename} s3://${V_int_from_aver}/DEV/all_medical_claims_batch_response/
elif [[ ${V_filetype} == *PROV* ]]
then
    aws s3 mv ${V_response_short_filename} s3://${V_int_from_aver}/DEV/provider_roster_response/
else
    echo $'\n\n\n\n\n\n\n\n\n\n Response File Move Failed'
    exit 1 
fi
</script>
      <loglevel>Basic</loglevel>
      <parallel>N</parallel>
      <draw>Y</draw>
      <nr>0</nr>
      <xloc>3152</xloc>
      <yloc>304</yloc>
      <attributes_kjc />
    </entry>
    <entry>
      <name>update errors_and_rejects_details__response_file_transaction_processing_status</name>
      <description />
      <type>SQL</type>
      <attributes />
      <sql>delete from ${V_schema_name}.reject_count where interchange_control_number = '${V_icn}';

insert into ${V_schema_name}.reject_count
(select 
'${V_icn}' as interchange_control_number,
(select count(*) from ${V_schema_name}.errors_and_rejects_details where interchange_control_number = '${V_icn}' and transaction_processing_status = 'R') as reject_count
);

update ${V_schema_name}.errors_and_rejects_details
set response_file_transaction_processing_status = case
	when l.reject_count > 0 then  'R' else 'E' end
from ${V_schema_name}.reject_count l
where errors_and_rejects_details.interchange_control_number = l.interchange_control_number
;

delete from ${V_schema_name}.reject_count where interchange_control_number = '${V_icn}';</sql>
