    <entry>
      <name>Update Member and Enrollment records</name>
      <description />
      <type>SQL</type>
      <attributes />
      <sql>begin;

truncate ${V_schema_name}.member_staging;

begin;

truncate ${V_schema_name}.enrollment_staging;

COPY ${V_schema_name}.member_staging
(last_change_date,member_id,id,gender,person_id,zip_code,state,last_name,first_name,date_of_death,load_timestamp,source_document_control_number,load_date,date_of_birth,middle_name,county_code,minimum_data_date,maximum_data_date,cbsa_code,source_file_type)
FROM 's3://aver-client-${V_data_key}/integration/etl/staging/${V_data_key}_member_staging_${V_icn}.csv' 
iam_role 'arn:aws:iam::781803879514:role/redshift-pentaho-role'
CSV;

COPY ${V_schema_name}.enrollment_staging
(id,member_id,effective_date,termination_date,division,employer_id,employer_name,health_plan_member_id,health_plan_state,last_change_date,line_of_business,major_customer_segment,load_timestamp,policy_number,relationship,source_document_control_number,group_id,pcp_indicator,multi_coverage_indicator,health_plan_product_name,load_date,account_id,corporate_entity_code,enrollment_member_id,plan_code,dual_status_code,family_id,medicare_entitlement_code,medicare_orec_code,medicare_status_code,mhsa_coverage_indicator,coverage_type,group_name,internal_member_id,medicaid_id,medicare_id,product,program,source_file_type,subscriber_id,benefit_type_code,primary_care_provider_effective_date)
FROM 's3://aver-client-${V_data_key}/integration/etl/staging/${V_data_key}_enrollment_staging_${V_icn}.csv' 
iam_role 'arn:aws:iam::781803879514:role/redshift-pentaho-role'
CSV;

-- MEMBER UPDATE
delete from ${V_schema_name}.member where id in (select x.id from ${V_schema_name}.member_staging x);	
insert into ${V_schema_name}.member select x.* from ${V_schema_name}.member_staging x;

-- ENROLLMENT UPDATE
delete from ${V_schema_name}.enrollment where id in (select x.id from ${V_schema_name}.enrollment_staging x);
insert into ${V_schema_name}.enrollment select x.* from ${V_schema_name}.enrollment_staging x;

update ${V_schema_name}.enrollment
set termination_date = '9999-12-31'
where termination_date is NULL
;</sql>
      <useVariableSubstitution>T</useVariableSubstitution>
      <sqlfromfile>F</sqlfromfile>
      <sqlfilename />
      <sendOneStatement>F</sendOneStatement>
      <connection>GENERIC REDSHIFT CONNECTION</connection>
      <parallel>N</parallel>
      <draw>Y</draw>
      <nr>0</nr>
