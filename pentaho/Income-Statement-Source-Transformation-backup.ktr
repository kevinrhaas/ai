      <schema_name/>
    </partitioning>
    <send_true_to>Modified JavaScript value</send_true_to>
    <send_false_to>Add constants</send_false_to>
    <compare>
      <condition>
        <negated>N</negated>
        <leftvalue>content_bytes</leftvalue>
        <function>&gt;</function>
        <rightvalue>maxchars</rightvalue>
      </condition>
    </compare>
    <attributes/>
    <cluster_schema/>
    <remotesteps>
