  <step>
    <name>JSON: Extract to rows</name>
    <type>StructuredExtract</type>
    <description/>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <INCOMING_STRUCTURED_FIELD_NAME>result</INCOMING_STRUCTURED_FIELD_NAME>
    <PASS_THROUGH_FIELDS>Y</PASS_THROUGH_FIELDS>
    <EXTRACT_FIELDS>
      <STRUCTURED_PATH>$.id</STRUCTURED_PATH>
      <OUTPUT_FIELD_NAME>id</OUTPUT_FIELD_NAME>
      <OUTPUT_FIELD_TYPE>String</OUTPUT_FIELD_TYPE>
      <OUTPUT_PATH_FIELD_NAME/>
      <INPUT_STRUTURED_FIELD_NAME/>
    </EXTRACT_FIELDS>
    <EXTRACT_FIELDS>
      <STRUCTURED_PATH>$.choices[0].message.content</STRUCTURED_PATH>
      <OUTPUT_FIELD_NAME>content</OUTPUT_FIELD_NAME>
      <OUTPUT_FIELD_TYPE>String</OUTPUT_FIELD_TYPE>
      <OUTPUT_PATH_FIELD_NAME/>
      <INPUT_STRUTURED_FIELD_NAME/>
    </EXTRACT_FIELDS>
    <EXTRACT_FIELDS>
      <STRUCTURED_PATH>$.error.message</STRUCTURED_PATH>
      <OUTPUT_FIELD_NAME>error</OUTPUT_FIELD_NAME>
      <OUTPUT_FIELD_TYPE>String</OUTPUT_FIELD_TYPE>
      <OUTPUT_PATH_FIELD_NAME/>
      <INPUT_STRUTURED_FIELD_NAME/>
    </EXTRACT_FIELDS>
    <attributes/>
