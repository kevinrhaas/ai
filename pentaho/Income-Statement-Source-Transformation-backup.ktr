    <name>Modified JavaScript value</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>N</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
// Example usage
var delimiter = '~';
resultOut = insertDelimiter(content_user, maxchars, delimiter);

</jsScript_script>
      </jsScript>
      <jsScript>
        <jsScript_type>1</jsScript_type>
        <jsScript_name>Item_0</jsScript_name>
        <jsScript_script>//Script here

function insertDelimiter(text, maxCharacters, delimiter) {
 // Initialize an empty array to store the result
  var result = [];
  var charCount = 0;

  // Iterate over each character in the text
  for (var i = 0; i &lt; text.length; i++) {
    // Add the current character to the result array
    result.push(text[i]);
    charCount++;

    // Check if the character count exceeds maxCharacters and the current character is a whitespace
    if (charCount >= maxCharacters &amp;&amp; (text[i] === ' ' || text[i] === '\t')) {
      // Insert the delimiter
      result.push(delimiter);
      // Reset the character count
      charCount = 0;
    }
  }

  // Join the result array to form the final string
  return result.join('');
}
</jsScript_script>
      </jsScript>
    </jsScripts>
