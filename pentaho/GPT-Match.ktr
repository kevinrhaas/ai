        <jsScript_script>//Script here


var data_string = {
    "model": model,
    "messages": [
        {
            "role": "system",
            "content": content_system + content_system_custom
        },
        {
            "role": "user",
            "content": vendor
        }
    ],
    "temperature": temperature
}

var data_string = JSON.stringify(data_string)
</jsScript_script>
