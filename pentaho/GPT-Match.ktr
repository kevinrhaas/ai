        <jsScript_script>//Script here


var obj = JSON.parse(result);


firstKey = Object.keys(obj)[0];

    if (firstKey === "error") {
        // The object starts with an "error" key
        // Handle this case differently
        var content = "Service Exception";
    } else {
        // Handle normal case
        var content = obj.choices[0].message.content;
    }



</jsScript_script>
